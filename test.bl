function fib(int n) -> int {
    if (n == 0) {
        return 0;
    }

    if (n == 1) {
        return 1;
    }

    return fib(n - 1) + fib(n - 2);
}

function add(int a, int b) -> int {
    int result = a + b * 2;
    return result;
}

function main() -> int {
    int x = 10;
    int y = 20;

    int z;
    z = x + y * 3 - 5 / 2;

    if (z > 30 && x < y) {
        z = z + 1;
    } else {
        z = z - 1;
    }

    while (x < 100) {
        x = x + 1;
    }

    for (int i = 0; i < 10; i = i + 1) {
        z = z + i;
    }

    for (x = 0; x < 5; x = x + 1) {
        z = z + x;
    }

    return add(x, y);
}